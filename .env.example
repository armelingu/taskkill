## Sessão / Auth (web)
# Segredo do Flask (use um valor longo e aleatório)
TASKKILL_SECRET_KEY=troque-por-um-segredo-grande-e-aleatorio

# Admin inicial (criado no primeiro boot se não existir usuário)
TASKKILL_ADMIN_USER=admin
TASKKILL_ADMIN_PASSWORD=troque-por-uma-senha-grande

# Cookies (na VPS com HTTPS, deixe 1)
TASKKILL_COOKIE_SECURE=1

## Modelo do Ollama (pequeno e responsivo)
OLLAMA_MODEL=llama3.2:3b

## VPS / Proxy (Caddy)
# Para testar sem domínio: DOMAIN=:80 (apenas HTTP)
DOMAIN=taskkill.seudominio.com
BASIC_AUTH_USER=usuario
# Gere o hash com:
#   docker run --rm caddy:2 caddy hash-password --plaintext "SUA_SENHA"
BASIC_AUTH_HASH=$2a$14$troque-por-um-hash-bcrypt-valido

