## Token fixo (necessário em produção/Gunicorn para não variar por processo)
TASKKILL_API_TOKEN=troque-por-um-token-grande-e-aleatorio

## Modelo do Ollama (pequeno e responsivo)
OLLAMA_MODEL=llama3.2:3b

## VPS / Proxy (Caddy)
# Para testar sem domínio: DOMAIN=:80 (apenas HTTP)
DOMAIN=taskkill.seudominio.com
BASIC_AUTH_USER=usuario
# Gere o hash com:
#   docker run --rm caddy:2 caddy hash-password --plaintext "SUA_SENHA"
BASIC_AUTH_HASH=$2a$14$troque-por-um-hash-bcrypt-valido

