## ===== Taskkill =====

# Obrigatório: chave secreta longa e aleatória (ex: python -c "import secrets; print(secrets.token_hex(32))")
TASKKILL_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Obrigatório no 1º boot: credenciais do admin inicial (senha >= 10 chars)
TASKKILL_ADMIN_USER=admin
TASKKILL_ADMIN_PASSWORD=troque-por-senha-forte

# Em produção (HTTPS), defina como 1
TASKKILL_COOKIE_SECURE=0

## Ollama (opcional — assistente local)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

## ===== Integração Chamados (MySQL) =====
# Ligue/desligue o import automático (0 = desligado)
CHAMADOS_SYNC_ENABLED=0

CHAMADOS_MYSQL_HOST=SEU_HOST_MYSQL
CHAMADOS_MYSQL_PORT=3306
CHAMADOS_MYSQL_DB=SEU_BANCO
CHAMADOS_MYSQL_USER=SEU_USUARIO
CHAMADOS_MYSQL_PASSWORD=SUA_SENHA

# ID do agente cujos chamados serão importados
CHAMADOS_AGENT_ID=0

# Intervalo de polling em segundos
CHAMADOS_POLL_SECONDS=45
CHAMADOS_FETCH_LIMIT=200

## ===== VPS / Caddy (só se for usar em produção) =====
# TASKKILL_COOKIE_SECURE=1
# DOMAIN=taskkill.seudominio.com
# BASIC_AUTH_USER=usuario
# IMPORTANTE: no .env do Docker Compose, escape $ com $$:
# BASIC_AUTH_HASH=$$2a$$14$$SEU_HASH_BCRYPT_AQUI
